# Production: call via Cloudflare Worker proxy (API key hidden server-side)
VITE_WORKER_URL=https://your-worker.workers.dev

# Local dev only: call Gemini directly from browser (bypasses Node.js SSL issues)
# When set, VITE_WORKER_URL is ignored — remove this line for production build
VITE_GEMINI_API_KEY=your_google_ai_studio_key_here
